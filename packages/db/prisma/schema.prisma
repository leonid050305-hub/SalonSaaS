generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Мультиарендность ────────────────────────────────────────────────────────

model Tenant {
  id          String    @id @default(uuid())
  name        String
  plan        Plan      @default(FREE)
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())

  salons  Salon[]
  users   User[]
}

enum Plan {
  FREE
  STARTER
  PRO
}

// ─── Пользователи (владельцы / администраторы) ───────────────────────────────

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
}

// ─── Салоны ──────────────────────────────────────────────────────────────────

model Salon {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  address  String?
  phone    String?
  timezone String  @default("Europe/Moscow")
  isActive Boolean @default(true)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff        Staff[]
  services     Service[]
  clients      Client[]
  appointments Appointment[]
}

// ─── Мастера ─────────────────────────────────────────────────────────────────

model Staff {
  id       String  @id @default(uuid())
  salonId  String
  name     String
  phone    String?
  role     String? // "Парикмахер", "Мастер маникюра" и т.д.
  // Расписание: { mon: {start:"09:00", end:"18:00"}, tue: null, ... }
  schedule Json    @default("{}")
  isActive Boolean @default(true)

  salon         Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staffServices StaffService[]
  appointments  Appointment[]
}

// ─── Услуги ──────────────────────────────────────────────────────────────────

model Service {
  id          String  @id @default(uuid())
  salonId     String
  name        String
  durationMin Int // длительность в минутах
  price       Decimal @db.Decimal(10, 2)
  category    String? // "Волосы", "Ногти", "Брови" и т.д.
  isActive    Boolean @default(true)

  salon            Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staffServices    StaffService[]
  appointmentItems AppointmentItem[]
}

// ─── Связь мастер ↔ услуга ───────────────────────────────────────────────────

model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

// ─── Клиенты ─────────────────────────────────────────────────────────────────

model Client {
  id            String    @id @default(uuid())
  salonId       String
  name          String
  phone         String?
  email         String?
  loyaltyPoints Int       @default(0)
  notes         String?
  lastVisitAt   DateTime?
  createdAt     DateTime  @default(now())

  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([salonId, phone])
}

// ─── Записи ──────────────────────────────────────────────────────────────────

model Appointment {
  id         String            @id @default(uuid())
  salonId    String
  clientId   String
  staffId    String
  startsAt   DateTime
  endsAt     DateTime
  status     AppointmentStatus @default(PENDING)
  source     BookingSource     @default(MANUAL)
  notes      String?
  totalPrice Decimal           @db.Decimal(10, 2)
  createdAt  DateTime          @default(now())

  salon   Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id])
  staff   Staff   @relation(fields: [staffId], references: [id])
  items   AppointmentItem[]
}

enum AppointmentStatus {
  PENDING    // ожидает подтверждения
  CONFIRMED  // подтверждена
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW    // не пришёл
}

enum BookingSource {
  MANUAL    // администратор создал вручную
  ONLINE    // через виджет на сайте
  WHATSAPP
  INSTAGRAM
  PHONE
}

// ─── Позиции записи (одна запись = несколько услуг) ─────────────────────────

model AppointmentItem {
  id            String  @id @default(uuid())
  appointmentId String
  serviceId     String
  price         Decimal @db.Decimal(10, 2)
  durationMin   Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])
}
